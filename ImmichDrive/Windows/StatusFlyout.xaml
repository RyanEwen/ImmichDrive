<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ImmichDrive.Windows.StatusFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="Root" Padding="18,16,18,18" RowSpacing="12" Width="300" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Image x:Name="Icon" Width="22" Height="22" VerticalAlignment="Center" />
                <TextBlock Text="Drive for Immich" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button x:Name="RefreshButton" Click="RefreshButton_Click"
                        Padding="7" MinWidth="0" Background="Transparent" BorderBrush="Transparent"
                        ToolTipService.ToolTip="Refresh now">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
                <Button x:Name="SettingsButton" Click="SettingsButton_Click"
                        Padding="7" MinWidth="0" Background="Transparent" BorderBrush="Transparent"
                        ToolTipService.ToolTip="Settings">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock x:Name="StatusText" Opacity="0.85" TextWrapping="Wrap" />
            <ProgressBar x:Name="SyncProgress" Visibility="Collapsed" />
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="OpenFolderButton" Click="OpenFolderButton_Click"
                    HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}"
                    Content="Open folder" ToolTipService.ToolTip="Open drive folder" />
            <Button Grid.Column="1" x:Name="OpenImmichButton" Click="OpenImmichButton_Click"
                    HorizontalAlignment="Stretch" Content="Open Immich" />
        </Grid>
    </Grid>
</Window>
