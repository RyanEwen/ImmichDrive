<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ImmichDrive.Windows.StatusFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="Root" Padding="18,16,18,18" RowSpacing="12" Width="300">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <Image x:Name="Icon" Width="22" Height="22" VerticalAlignment="Center" />
            <TextBlock Text="ImmichDrive" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock x:Name="StatusText" Opacity="0.85" TextWrapping="Wrap" />
            <ProgressBar x:Name="SyncProgress" Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button x:Name="OpenFolderButton" Click="OpenFolderButton_Click"
                    Style="{StaticResource AccentButtonStyle}" Content="Open drive folder" />
            <Button x:Name="SettingsButton" Click="SettingsButton_Click" Content="Settings" />
        </StackPanel>
    </Grid>
</Window>
