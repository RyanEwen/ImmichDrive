<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ImmichDrive.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
    <StackPanel MaxWidth="1000" Margin="16">
        <TextBlock Text="About" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- App identity -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image x:Name="AppIcon" Width="32" Height="32" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="ImmichDrive" FontSize="16" FontWeight="Medium"/>
                    <TextBlock x:Name="VersionText" FontSize="12" Opacity="0.6"/>
                    <TextBlock Text="Your Immich photo library as a native Windows cloud drive — browse by date, with thumbnails, without filling up your disk."
                               FontSize="13" Opacity="0.6" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- How it works -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE753;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="How it works" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="Uses the Windows Cloud Files API to show your photos as on-demand placeholder files. They appear in File Explorer with real thumbnails but take up no space until you open one — then ImmichDrive streams just that file from your server."
                               FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Server -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE968;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Immich" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="The self-hosted photo and video backup the drive is powered by." FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <HyperlinkButton Grid.Column="2" Content="immich.app"
                                 NavigateUri="https://immich.app" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Built With -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE943;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Built With" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="WinUI 3 · .NET 10 · Windows App SDK · Cloud Files API · CommunityToolkit.Mvvm · SQLite · NLog"
                               FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- License -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE8A5;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="License" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="PolyForm Noncommercial License 1.0.0 — free for personal and noncommercial use. Copyright © 2026 Ryan Ewen."
                               FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>
