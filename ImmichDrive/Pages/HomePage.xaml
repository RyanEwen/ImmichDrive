<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ImmichDrive.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32,16,32,32">
        <StackPanel Spacing="16" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Drive for Immich" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Your Immich photos, in File Explorer — without filling up your disk."
                       Opacity="0.7" Margin="0,-8,0,0" />

            <InfoBar x:Name="StatusBar" IsOpen="True" IsClosable="False" />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE8B7;" FontSize="22" VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Drive folder" Opacity="0.7" FontSize="12" />
                            <TextBlock x:Name="FolderText" Style="{StaticResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                    <ProgressBar x:Name="SyncProgress" Visibility="Collapsed" />
                    <TextBlock x:Name="DetailText" Opacity="0.7" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="OpenFolderButton" Click="OpenFolderButton_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE838;" FontSize="14" />
                                <TextBlock Text="Open drive folder" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="RefreshButton" Click="RefreshButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                <TextBlock Text="Refresh" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ConfigureButton" Click="ConfigureButton_Click" Content="Set up connection" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
