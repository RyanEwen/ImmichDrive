<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ImmichDrive.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32,16,32,32">
        <StackPanel Spacing="8" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8" />

            <!-- Theme -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16,12">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="App theme" FontWeight="SemiBold" />
                        <TextBlock Text="Appearance of this settings window." Opacity="0.7" />
                    </StackPanel>
                    <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Right" MinWidth="160"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="System default" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Read-only -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16,12">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Read-only drive" FontWeight="SemiBold" />
                        <TextBlock Text="Block edits, deletes, renames and new files. Use the Upload folder to add photos to Immich."
                                   Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch x:Name="ReadOnlyToggle" HorizontalAlignment="Right" MinWidth="0"
                                  Toggled="ReadOnlyToggle_Toggled" />
                </Grid>
            </Border>

            <!-- Startup -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16,12">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Start at sign-in" FontWeight="SemiBold" />
                        <TextBlock Text="Keep the drive online by launching ImmichDrive when you sign in."
                                   Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch x:Name="StartupToggle" HorizontalAlignment="Right" MinWidth="0"
                                  Toggled="StartupToggle_Toggled" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
